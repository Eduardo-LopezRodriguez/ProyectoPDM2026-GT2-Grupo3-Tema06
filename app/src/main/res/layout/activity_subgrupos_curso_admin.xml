<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#B71C1C"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvTituloCurso"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Subgrupos del curso"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCicloCursoDetalle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Ciclo académico"
            android:textColor="#FFCDD2"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Botón crear subgrupo -->
    <Button
        android:id="@+id/btnCrearSubgrupo"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_margin="16dp"
        android:backgroundTint="#B71C1C"
        android:text="+ Crear subgrupo"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="15sp" />

    <!-- Estado vacío -->
    <TextView
        android:id="@+id/tvSinSubgrupos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:gravity="center"
        android:padding="20dp"
        android:text="No hay subgrupos para este curso."
        android:textColor="#888888"
        android:textSize="15sp"
        android:visibility="gone" />

    <!-- Lista -->
    <ListView
        android:id="@+id/lvSubgrupos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@null"
        android:padding="8dp" />

</LinearLayout>
