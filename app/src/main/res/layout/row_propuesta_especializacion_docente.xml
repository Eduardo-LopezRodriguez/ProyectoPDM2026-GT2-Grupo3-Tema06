<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card_white"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/tvTituloPropuestaDocente"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Título"
        android:textColor="#222222"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvEstadoPropuestaDocente"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_badge_gray"
        android:paddingHorizontal="10dp"
        android:paddingVertical="6dp"
        android:text="Estado: Pendiente"
        android:textColor="#222222"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvDescripcionPropuestaDocente"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Descripción"
        android:textColor="#444444"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/tvArchivoPropuestaDocente"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Archivo: Sin archivo adjunto"
        android:textColor="#555555"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvFechaPropuestaDocente"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Fecha: Sin fecha"
        android:textColor="#777777"
        android:textSize="13sp" />

    <EditText
        android:id="@+id/etObservacionPropuestaDocente"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_edittext_border"
        android:gravity="top|start"
        android:hint="Observación del docente"
        android:inputType="textMultiLine|textCapSentences"
        android:padding="12dp"
        android:textColor="#222222"
        android:textColorHint="#777777" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnAprobarPropuestaDocente"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="5dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_green"
            android:text="Aprobar"
            android:textAllCaps="false"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/btnObservacionPropuestaDocente"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="5dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_gray"
            android:text="Observar"
            android:textAllCaps="false"
            android:textColor="#222222" />

        <Button
            android:id="@+id/btnDenegarPropuestaDocente"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_red"
            android:text="Denegar"
            android:textAllCaps="false"
            android:textColor="@android:color/white" />
    </LinearLayout>
</LinearLayout>
