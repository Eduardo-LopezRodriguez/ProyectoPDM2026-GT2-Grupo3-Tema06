<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="6dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvTituloPropuesta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Título de la Propuesta"
            android:textColor="#212121"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvEstadoPropuesta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Estado: Pendiente"
            android:textColor="#333333"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvFechaRegistroPropuesta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Fecha de Registro: DD/MM/AAAA"
            android:textColor="#424242"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvObservacionPropuesta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Observación: Sin observaciones."
            android:textColor="#424242"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvUrlDocumentoPropuesta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:autoLink="web"
            android:text="Documento: Sin archivo"
            android:textColor="#424242"
            android:textSize="12sp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>