<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvNombreDocumentoRevision"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nombre del Documento"
            android:textColor="#212121"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTrabajoModalidadRevision"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Trabajo: Nombre Trabajo (Modalidad)"
            android:textColor="#333333"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvEstudianteRevision"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Estudiante: Nombre Estudiante (AA12345)"
            android:textColor="#333333"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvTipoVersionDocumentoRevision"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Tipo: Perfil | Versión: 1"
            android:textColor="#333333"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvEstadoDocumentoRevision"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Estado: Pendiente"
            android:textColor="#B71C1C"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvFechaCargaRevision"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Fecha de Carga: DD/MM/AAAA"
            android:textColor="#424242"
            android:textSize="12sp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>