<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#B71C1C"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Crear subgrupo"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCursoSubgrupo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Curso: —"
                android:textColor="#FFCDD2"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Formulario -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombre del subgrupo *"
                android:textColor="#212121"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etNombreSubgrupo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="#FFFFFF"
                android:hint="Ej. Subgrupo A"
                android:inputType="textCapSentences"
                android:padding="12dp"
                android:textColor="#212121"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Tema asignado (opcional)"
                android:textColor="#212121"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etTemaSubgrupo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="#FFFFFF"
                android:hint="Ej. Desarrollo de API REST"
                android:inputType="textCapSentences|textMultiLine"
                android:minLines="2"
                android:padding="12dp"
                android:textColor="#212121"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnGuardarSubgrupo"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="28dp"
                android:backgroundTint="#B71C1C"
                android:text="Guardar subgrupo"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btnCancelarSubgrupo"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:backgroundTint="#FFFFFF"
                android:text="Cancelar"
                android:textAllCaps="false"
                android:textColor="#B71C1C"
                android:textSize="16sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
