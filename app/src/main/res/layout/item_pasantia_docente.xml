<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvTituloPasantia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nombre del Proyecto de Pasantía"
            android:textColor="#212121"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvEstudiantePasantia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Estudiante: Nombre Apellido (AA12345)"
            android:textColor="#333333"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvEmpresaPasantia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Empresa: Nombre de la Empresa"
            android:textColor="#333333"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvEstadoPasantia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Estado: Activo"
            android:textColor="#333333"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvTotalBitacoras"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Bitácoras: 0"
                android:textColor="#424242"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvEstadoMemoria"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Memoria: Pendiente"
                android:textAlignment="viewEnd"
                android:textColor="#424242"
                android:textSize="13sp" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>