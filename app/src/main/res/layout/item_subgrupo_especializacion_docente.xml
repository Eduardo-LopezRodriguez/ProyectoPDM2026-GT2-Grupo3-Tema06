<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvNombreSubgrupo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nombre del Subgrupo"
            android:textColor="#212121"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTemaAsignado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Tema Asignado: Tema del Subgrupo"
            android:textColor="#333333"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvEstadoSubgrupo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Estado: Activo"
                android:textColor="#424242"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvTotalEstudiantesSubgrupo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Estudiantes: 0"
                android:textAlignment="viewEnd"
                android:textColor="#424242"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvPromedioGeneralSubgrupo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Promedio General: 0.00"
            android:textColor="#424242"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnRevisarPropuestasSubgrupo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_gray"
            android:text="Revisar propuestas"
            android:textAllCaps="false"
            android:textColor="#222222" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
