<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".ui.dashboard.docente.DetalleBitacoraDocenteActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:navigationIcon="@drawable/ic_back"
        app:title="Detalle de Bitácora" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDetalleTituloActividad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceHeadline5"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                tools:text="Título de la Actividad: Configuración inicial" />

            <TextView
                android:id="@+id/tvDetalleFechaActividad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceSubtitle1"
                android:layout_marginBottom="4dp"
                tools:text="Fecha: 2026-04-10" />

            <TextView
                android:id="@+id/tvDetalleTotalHoras"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceSubtitle1"
                android:layout_marginBottom="16dp"
                tools:text="Horas: 4" />

            <TextView
                android:id="@+id/tvDetalleEstudianteBitacora"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceSubtitle1"
                android:layout_marginBottom="4dp"
                tools:text="Estudiante: Eduardo Enrique López Rodríguez (LR21008)" />

            <TextView
                android:id="@+id/tvDetalleTrabajoEmpresa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceSubtitle1"
                android:layout_marginBottom="16dp"
                tools:text="Trabajo: Pasantía profesional en empresa colaboradora (Crowley Shared Services S.A.)" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Descripción de la Actividad:"
                android:textAppearance="?attr/textAppearanceSubtitle2"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvDetalleDescripcionActividad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceBody1"
                android:layout_marginBottom="16dp"
                tools:text="Configuración del entorno de desarrollo, instalación de dependencias, etc."
                android:justificationMode="inter_word" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Estado de la Bitácora:"
                android:textAppearance="?attr/textAppearanceSubtitle2"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerEstadoBitacora"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Observación del Docente:"
                android:textAppearance="?attr/textAppearanceSubtitle2"
                android:layout_marginBottom="4dp" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etObservacionBitacora"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Escribe tus observaciones aquí..."
                android:gravity="top"
                android:minLines="3"
                android:maxLines="6"
                android:inputType="textMultiLine"
                android:layout_marginBottom="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnActualizarEstadoBitacora"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Actualizar Estado de Bitácora" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>