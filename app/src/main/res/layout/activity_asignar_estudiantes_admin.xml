<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#B71C1C"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvTituloSubgrupo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Asignar estudiantes"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSubtituloSubgrupo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Máximo 3 estudiantes por subgrupo"
            android:textColor="#FFCDD2"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Contador de asignados -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFEBEE"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Estudiantes asignados:"
            android:textColor="#B71C1C"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvContadorAsignados"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 / 3"
            android:textColor="#B71C1C"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Estado vacío -->
    <TextView
        android:id="@+id/tvSinAlumnos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:gravity="center"
        android:padding="20dp"
        android:text="No hay alumnos activos disponibles."
        android:textColor="#888888"
        android:textSize="15sp"
        android:visibility="gone" />

    <!-- Lista de alumnos -->
    <ListView
        android:id="@+id/lvAlumnos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@null"
        android:padding="8dp" />

</LinearLayout>
