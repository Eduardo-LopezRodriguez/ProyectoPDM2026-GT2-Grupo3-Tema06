<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#B71C1C"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Volver"
                android:padding="8dp"
 />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="Detalle de Pasantía"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvDetalleTituloPasantia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Título del Proyecto de Pasantía"
                android:textColor="#212121"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDetalleEstudiante"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Estudiante: Nombre Apellido (AA12345)"
                android:textColor="#333333"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvDetalleEmpresa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Empresa: Nombre de la Empresa"
                android:textColor="#333333"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvDetallePersonero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Contacto Empresa: Nombre del Personero"
                android:textColor="#333333"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvDetalleEstadoPasantia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Estado: Activo"
                android:textColor="#333333"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvDetalleTotalBitacoras"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Bitácoras registradas: 0"
                android:textColor="#333333"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvDetalleEstadoMemoria"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Estado de la memoria: Pendiente"
                android:textColor="#333333"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btnVerBitacoras"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Ver Bitácoras"
                android:backgroundTint="#B71C1C"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnVerMemoria"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Ver Memoria Final"
                android:backgroundTint="#B71C1C"
                android:textColor="#FFFFFF" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>