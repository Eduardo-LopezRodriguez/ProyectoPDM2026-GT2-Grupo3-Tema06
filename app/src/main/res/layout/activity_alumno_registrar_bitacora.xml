<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F2F2">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#B30000"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp">

        <ImageButton
            android:id="@+id/btnBackRegistrarBitacoraAlumno"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:contentDescription="Regresar"
            android:src="@android:drawable/ic_media_previous"
            app:tint="@android:color/white"
            tools:ignore="TouchTargetSizeCheck" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Bitácoras de pasantía"
            android:textColor="@android:color/white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <View
            android:layout_width="32dp"
            android:layout_height="32dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Registrar bitácora"
                android:textColor="#222222"
                android:textSize="22sp"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#F4DFC8"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="Información"
                        android:src="@android:drawable/ic_dialog_info"
                        app:tint="#C9801A" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="Describe claramente la actividad que realizaste, paso a paso. Puedes adjuntar evidencias opcionales."
                        android:textColor="#C9801A"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Título"
                android:textColor="#222222"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etTituloBitacoraAlumno"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:background="@android:drawable/edit_text"
                android:hint="Ingresa el título"
                android:inputType="textCapSentences"
                android:paddingHorizontal="12dp"
                android:textColor="#222222"
                android:textColorHint="#888888" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Fecha"
                android:textColor="#222222"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etFechaBitacoraAlumno"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:background="@android:drawable/edit_text"
                android:hint="DD/MM/AAAA"
                android:focusable="false"
                android:clickable="true"
                android:paddingHorizontal="12dp"
                android:textColor="#222222"
                android:textColorHint="#888888" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Horas trabajadas"
                android:textColor="#222222"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etHorasBitacoraAlumno"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:background="@android:drawable/edit_text"
                android:hint="Ej. 4"
                android:inputType="number"
                android:paddingHorizontal="12dp"
                android:textColor="#222222"
                android:textColorHint="#888888" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Descripción de la actividad"
                android:textColor="#222222"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etDescripcionBitacoraAlumno"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="10dp"
                android:background="@android:drawable/edit_text"
                android:gravity="top|start"
                android:hint="Describe la actividad realizada"
                android:inputType="textMultiLine|textCapSentences"
                android:padding="12dp"
                android:textColor="#222222"
                android:textColorHint="#888888" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Adjunto (opcional)"
                android:textColor="#222222"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/layoutAdjuntoBitacoraAlumno"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:contentDescription="Adjuntar archivo"
                    android:src="@android:drawable/ic_menu_upload"
                    app:tint="#B30000" />

                <TextView
                    android:id="@+id/tvAdjuntoBitacoraAlumno"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Adjuntar archivo"
                    android:textColor="#555555"
                    android:textSize="16sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnGuardarBitacoraAlumno"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="10dp"
                    android:backgroundTint="#B30000"
                    android:text="Agregar bitácora"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white" />

                <Button
                    android:id="@+id/btnCancelarBitacoraAlumno"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:backgroundTint="#B30000"
                    android:text="Cancelar"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomNavRegistrarBitacoraAlumno"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#424242"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp">

        <LinearLayout
            android:id="@+id/itemInicioRegistrarBitacoraAlumno"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#B30000"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="Inicio"
                android:src="@android:drawable/ic_menu_view"
                android:tint="@android:color/white"
                tools:ignore="UseAppTint" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/itemGrupoRegistrarBitacoraAlumno"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="Grupo"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="@android:color/white"
                tools:ignore="UseAppTint" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/itemPerfilRegistrarBitacoraAlumno"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="Perfil"
                android:src="@android:drawable/ic_menu_info_details"
                app:tint="@android:color/white" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
