<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#B71C1C"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Crear nuevo curso"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Complete los datos del curso de especialización"
                android:textColor="#FFCDD2"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Formulario -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombre del curso *"
                android:textColor="#212121"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etNombreCurso"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="#FFFFFF"
                android:hint="Ej. Desarrollo de aplicaciones móviles"
                android:inputType="textCapSentences"
                android:padding="12dp"
                android:textColor="#212121"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Ciclo académico *"
                android:textColor="#212121"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etCicloAcademico"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="#FFFFFF"
                android:hint="Ej. Ciclo I 2026"
                android:inputType="textCapSentences"
                android:padding="12dp"
                android:textColor="#212121"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Cupo máximo *"
                android:textColor="#212121"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etCupoMaximo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="#FFFFFF"
                android:hint="Ej. 30"
                android:inputType="number"
                android:padding="12dp"
                android:textColor="#212121"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Fecha de inicio *"
                android:textColor="#212121"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etFechaCreacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="#FFFFFF"
                android:focusable="false"
                android:hint="Seleccione una fecha"
                android:padding="12dp"
                android:textColor="#212121"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnGuardarCurso"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="28dp"
                android:backgroundTint="#B71C1C"
                android:text="Guardar curso"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btnCancelarCurso"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:backgroundTint="#FFFFFF"
                android:text="Cancelar"
                android:textAllCaps="false"
                android:textColor="#B71C1C"
                android:textSize="16sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
