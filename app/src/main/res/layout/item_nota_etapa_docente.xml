<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="6dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvNombreEtapaNota"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nombre de la Etapa"
            android:textColor="#212121"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvNotaValor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Nota: 0.00"
            android:textColor="#333333"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvNotaObservacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Observación: Sin observaciones."
            android:textColor="#333333"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvNotaFechaRegistro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Fecha de Registro: DD/MM/AAAA"
            android:textColor="#424242"
            android:textSize="12sp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>