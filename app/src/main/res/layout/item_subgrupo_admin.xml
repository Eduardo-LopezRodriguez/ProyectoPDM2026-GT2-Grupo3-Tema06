<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:elevation="2dp"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="5dp">

    <!-- Fila: nombre + badge alumnos -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvNombreSubgrupo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Subgrupo 01"
            android:textColor="#212121"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAlumnosSubgrupo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#B71C1C"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            android:text="0/3"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Tema -->
    <TextView
        android:id="@+id/tvTemaSubgrupo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Tema: —"
        android:textColor="#555555"
        android:textSize="13sp" />

    <!-- Docente responsable -->
    <TextView
        android:id="@+id/tvDocenteSubgrupo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Docente: —"
        android:textColor="#555555"
        android:textSize="13sp" />

    <!-- Botones -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:weightSum="2">

        <Button
            android:id="@+id/btnAsignarEstudiantes"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#FFEBEE"
            android:text="Asignar estudiantes"
            android:textAllCaps="false"
            android:textColor="#B71C1C"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnAsignarDocente"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:backgroundTint="#FFEBEE"
            android:text="Asignar docente"
            android:textAllCaps="false"
            android:textColor="#B71C1C"
            android:textSize="12sp" />
    </LinearLayout>

</LinearLayout>