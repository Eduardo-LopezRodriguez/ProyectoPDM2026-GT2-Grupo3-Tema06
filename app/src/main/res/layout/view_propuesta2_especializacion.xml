<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="14dp"
    android:background="@drawable/bg_card_white"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#B30000"
        android:gravity="center"
        android:padding="10dp"
        android:text="Propuesta 2"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <EditText
            android:id="@+id/etTituloPropuesta2Especializacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_edittext_border"
            android:hint="Título de la propuesta"
            android:inputType="textCapSentences"
            android:minHeight="48dp"
            android:padding="12dp"
            android:textColor="#222222"
            android:textColorHint="#777777" />

        <EditText
            android:id="@+id/etDescripcionPropuesta2Especializacion"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_edittext_border"
            android:gravity="top|start"
            android:hint="Descripción breve"
            android:inputType="textMultiLine|textCapSentences"
            android:padding="12dp"
            android:textColor="#222222"
            android:textColorHint="#777777" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/layoutAdjuntarPropuesta2Especializacion"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:gravity="center"
                    android:text="⇧"
                    android:textColor="#B30000"
                    android:textSize="24sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="Adjuntar archivo"
                    android:textColor="#444444"
                    android:textSize="16sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnGuardarPropuesta2Especializacion"
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_button_gray"
                android:text="Guardar"
                android:textAllCaps="false"
                android:textColor="#222222" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvArchivoSeleccionadoPropuesta2Especializacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Sin archivo adjunto"
            android:textColor="#555555"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>
