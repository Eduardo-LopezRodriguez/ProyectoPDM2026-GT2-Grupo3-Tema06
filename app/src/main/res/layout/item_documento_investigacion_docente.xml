<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="6dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvNombreDocumentoInvestigacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nombre del Documento"
            android:textColor="#212121"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTipoDocumentoInvestigacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Tipo: Perfil"
            android:textColor="#333333"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvVersionDocumentoInvestigacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Versión: 1"
            android:textColor="#333333"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvEstadoDocumentoInvestigacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Estado: Pendiente"
            android:textColor="#333333"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvFechaCargaDocumentoInvestigacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Fecha de Carga: DD/MM/AAAA"
            android:textColor="#424242"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvObservacionDocumentoInvestigacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Observación: Sin observaciones."
            android:textColor="#424242"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvUrlDocumentoInvestigacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:autoLink="web"
            android:text="Documento: Sin archivo"
            android:textColor="#424242"
            android:textSize="12sp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>