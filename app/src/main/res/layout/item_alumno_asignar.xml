<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:elevation="2dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp">

    <!-- Info alumno -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvNombreAlumno"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nombre del alumno"
            android:textColor="#212121"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCarnetAlumno"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Carnet: —"
            android:textColor="#555555"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvCorreoAlumno"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="correo@ues.edu.sv"
            android:textColor="#888888"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Botón asignar / quitar -->
    <Button
        android:id="@+id/btnToggleAsignar"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_marginStart="10dp"
        android:backgroundTint="#B71C1C"
        android:text="Asignar"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="12sp" />

</LinearLayout>
